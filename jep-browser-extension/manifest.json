{
  "manifest_version": 3,
  "name": "JEP Guard",
  "version": "1.0.0",
  "description": "保护您的加密交易免受恶意AI代理侵害，生成可验证的JEP收据。",
  "permissions": [
    "storage",
    "activeTab",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://*.gate.com/*",
    "https://*.bitget.com/*",
    "https://*.polymarket.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.gate.com/*",
        "https://*.bitget.com/*",
        "https://*.polymarket.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
